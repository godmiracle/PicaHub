# PicaHub live protocol Spike credentials.
# Xcode does not load this file automatically. Copy values into the test
# scheme environment or export them only for the test process.
PICACG_EMAIL=
PICACG_PASSWORD=

# Optional: set to "direct" to use picaapi.picacomic.com.
# The default is the go2778 proxy route.
PICACG_API_HOST=proxy

# Favorite mutation is disabled unless this is explicitly set to 1.
PICACG_ENABLE_MUTATION_SPIKE=0
